{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.12"
  },
  "caches": {
    "pip": {
      "directory": "/root/.cache/pip",
      "type": "shared"
    }
  },
  "steps": {
    "install": {
      "inputs": [
        { "local": true, "include": ["requirements.txt"] }
      ],
      "commands": [
        "pip install --cache-dir /root/.cache/pip -r requirements.txt"
      ],
      "caches": ["pip"]
    }
  },
  "deploy": {
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port $PORT",
    "inputs": [
      { "step": "install" },
      { "local": true, "include": ["app", "data"] }
    ],
    "variables": {
      "APP_HOST": "0.0.0.0",
      "APP_PORT": "$PORT",
      "LANGSMITH_TRACING": "false"
    }
  },
  "secrets": [
    "ILMU_API_KEY",
    "ILMU_BASE_URL",
    "ILMU_MODEL",
    "LANGSMITH_API_KEY",
    "LANGSMITH_PROJECT",
    "LANGSMITH_ENDPOINT",
    "AUTO_APPROVE_LIMIT_MYR",
    "ESCALATION_LIMIT_MYR"
  ]
}
